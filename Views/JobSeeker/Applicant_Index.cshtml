@model IEnumerable<Jobs>

@{
    ViewBag.Title = "Job Listings";
}

@if (ViewBag.alert != null)
{
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
}


@if (TempData["Message"] != null)
{
    <div class="alert alert-warning">
        @TempData["Message"]
    </div>
}


<div class="row">
    @foreach (var job in Model)
    {
        <div class="col-12 mb-2">
            <div class="px-3 py-2 border rounded bg-light shadow-sm">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@Html.DisplayFor(m => job.Title)</h5>
                        <small class="text-muted">@Html.DisplayFor(m => job.Location)</small>
                    </div>
                    <div>

                        @if (!job.hasApplied)
                        {
                            <form asp-action="Check" method="post">
                                <input type="hidden" name="JobId" value="@job.JobId" />
                                <button type="submit" class="btn btn-primary">Apply</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">You have already applied for this job.</span>
                        }

                        @* @if (role == "Admin" || role == "Recruiter")
                        {
                            @Html.ActionLink("Edit", "Update", new { id = job.JobId }, new { @class = "btn btn-sm btn-outline-primary me-2" })

                            @using (Html.BeginForm("Delete", "Jobs", FormMethod.Post, new { style = "display:inline;" }))
                            {
                                @Html.Hidden("id", job.JobId)
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            }
                        }
                        else
                        {
                            
                        } *@
                    </div>
                </div>
                <p class="mb-1 mt-2">@Html.DisplayFor(m => job.Description)</p>
                <div class="d-flex flex-wrap gap-3 small text-dark">
                    <span><strong>Salary:</strong> ₹@Html.DisplayFor(m => job.Salary)</span>
                    <span><strong>Posted:</strong> @Html.DisplayFor(m => job.PostedDate)</span>
                    <span><strong>Status:</strong> @Html.DisplayFor(m => job.Status)</span>
                </div>
            </div>
        </div>
    }
</div>

