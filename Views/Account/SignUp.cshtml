@model User
@{
    ViewData["Title"] = "Signup";
}

<style>
    .signup-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

        .signup-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000"><defs><radialGradient id="glow" cx="50%" cy="50%"><stop offset="0%" stop-color="rgba(255,255,255,0.2)"/><stop offset="100%" stop-color="rgba(255,255,255,0)"/></radialGradient></defs><circle cx="100" cy="100" r="50" fill="url(%23glow)"/><circle cx="900" cy="200" r="80" fill="url(%23glow)"/><circle cx="200" cy="900" r="70" fill="url(%23glow)"/><circle cx="800" cy="800" r="60" fill="url(%23glow)"/><circle cx="500" cy="300" r="40" fill="url(%23glow)"/><circle cx="300" cy="600" r="90" fill="url(%23glow)"/></svg>');
            opacity: 0.3;
            animation: glow-drift 15s infinite ease-in-out;
        }

    @@keyframes glow-drift {
        0%, 100%

    {
        transform: translateX(0) translateY(0);
    }

    25% {
        transform: translateX(20px) translateY(-10px);
    }

    50% {
        transform: translateX(-15px) translateY(15px);
    }

    75% {
        transform: translateX(10px) translateY(-20px);
    }

    }

    .form-wrapper {
        position: relative;
        z-index: 2;
    }

    .signup-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 40px 80px rgba(0, 0, 0, 0.2);
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        width: 520px;
        border-radius: 2.5rem;
        overflow: hidden;
        position: relative;
    }

        .signup-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #667eea, #764ba2, #f093fb, #667eea);
            background-size: 400% 100%;
            animation: rainbow-slide 3s infinite;
        }

    @@keyframes rainbow-slide {
        0%

    {
        background-position: 0% 0%;
    }

    100% {
        background-position: 400% 0%;
    }

    }

    .signup-card:hover {
        transform: translateY(-15px) scale(1.02);
        box-shadow: 0 50px 100px rgba(102, 126, 234, 0.4);
        background: rgba(255, 255, 255, 1);
    }

    .signup-title {
        background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 800;
        text-align: center;
        margin-bottom: 2.5rem;
        font-size: 2.8rem;
        position: relative;
        padding-top: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

        .signup-title::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 4px;
            background: linear-gradient(45deg, #667eea, #764ba2, #f093fb);
            border-radius: 2px;
            animation: title-pulse 2s infinite;
        }

    @@keyframes title-pulse {
        0%, 100%

    {
        width: 120px;
        opacity: 1;
    }

    50% {
        width: 160px;
        opacity: 0.7;
    }

    }

    .signup-title::before {
        content: '🚀';
        position: absolute;
        top: -20px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 2.5rem;
        animation: rocket-launch 4s infinite;
    }

    @@keyframes rocket-launch {
        0%, 80%, 100%

    {
        transform: translateX(-50%) translateY(0) rotate(0deg);
    }

    10%, 30% {
        transform: translateX(-50%) translateY(-10px) rotate(-15deg);
    }

    20% {
        transform: translateX(-50%) translateY(-20px) rotate(15deg);
    }

    40% {
        transform: translateX(-50%) translateY(-5px) rotate(-5deg);
    }

    }

    .form-group {
        position: relative;
        margin-bottom: 2rem;
    }

    .form-label {
        color: #2c3e50;
        font-weight: 700;
        margin-bottom: 0.8rem;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .form-control {
        border: 2px solid #e9ecef;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        background: rgba(255, 255, 255, 0.9);
        font-size: 1.05rem;
        padding: 1.2rem 4rem 1.2rem 1.8rem;
        position: relative;
        font-weight: 500;
    }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 35px rgba(102, 126, 234, 0.4);
            background: rgba(255, 255, 255, 1);
            transform: translateY(-4px);
            outline: none;
        }

    .input-container {
        position: relative;
    }

    .input-icon {
        position: absolute;
        right: 1.8rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.4rem;
        pointer-events: none;
        transition: all 0.3s ease;
        background: linear-gradient(45deg, #667eea, #f093fb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .form-control:focus + .input-icon {
        transform: translateY(-50%) scale(1.2) rotate(12deg);
        filter: drop-shadow(0 0 8px rgba(102, 126, 234, 0.5));
    }

    .role-section {
        background: linear-gradient(45deg, rgba(102, 126, 234, 0.1), rgba(240, 147, 251, 0.1));
        border-radius: 1.5rem;
        padding: 1.5rem 2rem;
        margin-bottom: 2rem;
        border: 2px solid rgba(102, 126, 234, 0.2);
        transition: all 0.3s ease;
    }

        .role-section:hover {
            background: linear-gradient(45deg, rgba(102, 126, 234, 0.15), rgba(240, 147, 251, 0.15));
            border-color: rgba(102, 126, 234, 0.3);
            transform: translateY(-2px);
        }

    .role-label {
        color: #667eea;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 1rem;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .role-options {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .form-check {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin: 0;
    }

    .form-check-input {
        width: 1.5rem;
        height: 1.5rem;
        margin: 0;
        accent-color: #667eea;
        transform: scale(1.2);
        cursor: pointer;
    }

    .form-check label {
        font-weight: 600;
        color: #495057;
        font-size: 1.1rem;
        cursor: pointer;
        transition: color 0.3s ease;
        user-select: none;
    }

    .form-check-input:checked + label {
        color: #667eea;
        font-weight: 700;
    }

    .btn-signup {
        background: linear-gradient(45deg, #28a745, #20c997, #17a2b8);
        background-size: 300% 300%;
        border: none;
        color: white;
        padding: 1.3rem 2.5rem;
        font-weight: 800;
        font-size: 1.3rem;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-top: 2rem;
        animation: btn-gradient 4s infinite;
    }

    @@keyframes btn-gradient {
        0%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    100% {
        background-position: 0% 50%;
    }

    }

    .btn-signup::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
        transition: left 0.7s;
    }

    .btn-signup:hover::before {
        left: 100%;
    }

    .btn-signup:hover {
        transform: translateY(-8px);
        box-shadow: 0 30px 60px rgba(40, 167, 69, 0.5);
        color: white;
        animation-duration: 2s;
    }

    .btn-signup:active {
        transform: translateY(-4px) scale(0.98);
        box-shadow: 0 20px 40px rgba(40, 167, 69, 0.4);
    }

    .login-link {
        text-align: center;
        margin-top: 2rem;
        padding: 1.5rem;
        background: rgba(102, 126, 234, 0.05);
        border-radius: 1rem;
        border: 1px solid rgba(102, 126, 234, 0.1);
    }

        .login-link p {
            margin: 0;
            color: #6c757d;
            font-size: 1rem;
            font-weight: 500;
        }

        .login-link a {
            color: #667eea;
            text-decoration: none;
            font-weight: 700;
            transition: all 0.3s ease;
            position: relative;
        }

            .login-link a:hover {
                color: #764ba2;
                text-shadow: 0 0 10px rgba(102, 126, 234, 0.5);
            }

            .login-link a::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 0;
                height: 2px;
                background: linear-gradient(45deg, #667eea, #764ba2);
                transition: width 0.3s ease;
            }

            .login-link a:hover::after {
                width: 100%;
            }

    .validation-summary {
        background: linear-gradient(45deg, rgba(220, 53, 69, 0.1), rgba(248, 215, 218, 0.3));
        border: 2px solid rgba(220, 53, 69, 0.3);
        border-radius: 1.5rem;
        padding: 1.5rem 2rem;
        margin-bottom: 2rem;
        animation: error-shake 0.8s ease-in-out;
    }

    .text-danger {
        color: #e74c3c !important;
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 0.6rem;
        animation: error-fade 0.4s ease;
    }

    @@keyframes error-fade {
        from

    {
        opacity: 0;
        transform: translateY(-15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@keyframes error-shake {
        0%, 20%, 40%, 60%, 80%

    {
        transform: translateX(0);
    }

    10%, 30%, 50%, 70%, 90% {
        transform: translateX(-8px);
    }

    }

    .field-name::before {
        content: '👤';
        margin-right: 0.5rem;
        font-size: 1.3rem;
    }

    .field-email::before {
        content: '📧';
        margin-right: 0.5rem;
        font-size: 1.3rem;
    }

    .field-password::before {
        content: '🔒';
        margin-right: 0.5rem;
        font-size: 1.3rem;
    }

    .field-role::before {
        content: '🎭';
        margin-right: 0.5rem;
        font-size: 1.3rem;
    }

    .floating-elements {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }

    .floating-element {
        position: absolute;
        font-size: 2rem;
        opacity: 0.1;
        animation: float-around 12s infinite ease-in-out;
    }

        .floating-element:nth-child(1) {
            left: 10%;
            animation-delay: 0s;
        }

        .floating-element:nth-child(2) {
            left: 80%;
            animation-delay: 3s;
        }

        .floating-element:nth-child(3) {
            left: 50%;
            animation-delay: 6s;
        }

        .floating-element:nth-child(4) {
            left: 25%;
            animation-delay: 9s;
        }

    @@keyframes float-around {
        0%, 100%

    {
        transform: translateY(100vh) rotate(0deg);
        opacity: 0;
    }

    10%, 90% {
        opacity: 0.1;
    }

    50% {
        transform: translateY(-50px) rotate(180deg);
    }

    }

    @@media (max-width: 768px) {
        .signup-card

    {
        width: 90%;
        margin: 1rem;
    }

    .signup-title {
        font-size: 2.2rem;
    }

    .role-options {
        gap: 2rem;
    }

    .form-control {
        padding: 1rem 3.5rem 1rem 1.5rem;
        font-size: 1rem;
    }

    .btn-signup {
        font-size: 1.1rem;
        padding: 1.1rem 2rem;
    }

    }
</style>

<div class="signup-container d-flex justify-content-center align-items-center min-vh-100">
    <div class="floating-elements">
        <div class="floating-element">✨</div>
        <div class="floating-element">🌟</div>
        <div class="floating-element">💫</div>
        <div class="floating-element">⭐</div>
    </div>

    <div class="form-wrapper">
        <div class="card signup-card shadow-lg p-5">
            <h2 class="signup-title">Join Us</h2>

            <form asp-action="Signup" method="post">
                @Html.ValidationSummary(true, "", new { @class = "text-danger validation-summary" })

                <div class="form-group mb-3">
                    @Html.LabelFor(model => model.Name, new { @class = "form-label fw-semibold field-name" })
                    <div class="input-container">
                        @Html.TextBoxFor(model => model.Name, new { @class = "form-control rounded-pill", placeholder = "Enter your full name..." })
                        <i class="fas fa-user input-icon"></i>
                    </div>
                    @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(model => model.Email, new { @class = "form-label fw-semibold field-email" })
                    <div class="input-container">
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control rounded-pill", placeholder = "Enter your email address..." })
                        <i class="fas fa-envelope input-icon"></i>
                    </div>
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(model => model.Password, new { @class = "form-label fw-semibold field-password" })
                    <div class="input-container">
                        @Html.PasswordFor(model => model.Password, new { @class = "form-control rounded-pill", placeholder = "Create a strong password..." })
                        <i class="fas fa-lock input-icon"></i>
                    </div>
                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                </div>

                <div class="role-section">
                    <div class="role-label field-role">Choose Your Role</div>
                    <div class="role-options">
                        <div class="form-check form-check-inline">
                            @Html.RadioButtonFor(model => model.Role, "Applicant", new { @class = "form-check-input", id = "applicant" })
                            <label for="applicant" class="form-check-label">🔍 Applicant</label>
                        </div>
                        <div class="form-check form-check-inline">
                            @Html.RadioButtonFor(model => model.Role, "Recruiter", new { @class = "form-check-input", id = "recruiter" })
                            <label for="recruiter" class="form-check-label">🏢 Recruiter</label>
                        </div>
                    </div>
                    @Html.ValidationMessageFor(model => model.Role, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn btn-signup w-100 rounded-pill">
                    <i class="fas fa-rocket me-2"></i>Start Your Journey
                </button>

                <div class="login-link">
                    <p>
                        Already have an account?
                        <a asp-action="Login" asp-controller="Account">Sign In Here</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">