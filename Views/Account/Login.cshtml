@model User
@{
    ViewData["Title"] = "Login";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%);
        --secondary-gradient: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
        --glass-bg: rgba(255, 255, 255, 0.95);
        --glass-border: rgba(59, 130, 246, 0.2);
    }

    .login-body {
        background: linear-gradient(135deg, #dbeafe 0%, #3b82f6 50%, #1e40af 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        position: relative;
        overflow-x: hidden;
    }

    .floating-shapes {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: -1;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.1;
        animation: float 15s infinite ease-in-out;
    }

        .shape:nth-child(1) {
            width: 80px;
            height: 80px;
            background: white;
            top: 10%;
            left: 10%;
            animation-delay: 0s;
        }

        .shape:nth-child(2) {
            width: 120px;
            height: 120px;
            background: white;
            top: 70%;
            left: 80%;
            animation-delay: 3s;
        }

        .shape:nth-child(3) {
            width: 60px;
            height: 60px;
            background: white;
            top: 40%;
            left: 90%;
            animation-delay: 6s;
        }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px) rotate(0deg);
        }

        50% {
            transform: translateY(-20px) rotate(180deg);
        }
    }

    .modern-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        box-shadow: 0 25px 45px rgba(59, 130, 246, 0.15);
        position: relative;
        overflow: hidden;
        animation: slideUp 0.8s ease-out;
        width: 450px;
    }

        .modern-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.4), transparent);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .login-title {
        color: #1e40af;
        font-size: 2.2rem;
        font-weight: 700;
        text-shadow: 0 2px 10px rgba(59, 130, 246, 0.1);
    }

    .login-subtitle {
        color: #60a5fa;
        font-size: 0.95rem;
        font-weight: 400;
        margin-bottom: 0;
    }

    .modern-form-control {
        background: rgba(255, 255, 255, 0.8) !important;
        border: 1px solid rgba(59, 130, 246, 0.2) !important;
        color: #1e40af !important;
        font-size: 1rem;
        padding: 1rem 1.25rem;
        transition: all 0.3s ease;
    }

        .modern-form-control:focus {
            background: rgba(255, 255, 255, 0.95) !important;
            border-color: rgba(59, 130, 246, 0.4) !important;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1) !important;
            color: #1e40af !important;
        }

        .modern-form-control::placeholder {
            color: rgba(59, 130, 246, 0.6) !important;
        }

    .modern-label {
        color: #1e40af !important;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .modern-btn-primary {
        background: var(--primary-gradient) !important;
        border: none !important;
        color: white !important;
        font-weight: 600;
        font-size: 1.1rem;
        padding: 1rem 2rem;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .modern-btn-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.6s;
        }

        .modern-btn-primary:hover::before {
            left: 100%;
        }

        .modern-btn-primary:hover {
            transform: translateY(-2px) !important;
            box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3) !important;
        }

    .modern-link {
        color: #3b82f6 !important;
        text-decoration: none !important;
        font-weight: 600;
        position: relative;
    }

        .modern-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: #3b82f6;
            transition: width 0.3s ease;
        }

        .modern-link:hover::after {
            width: 100%;
        }

    .modern-text-white {
        color: #60a5fa !important;
    }

    .modern-text-danger {
        color: #1e40af !important;
        font-size: 0.85rem;
    }

    @@media (max-width: 576px) {
        .modern-card {
            width: 95%;
            margin: 1rem;
        }

        .login-title {
            font-size: 1.8rem;
        }
    }
</style>

<div class="login-body">
    <div class="floating-shapes">
        <div class="shape"></div>
        <div class="shape"></div>
        <div class="shape"></div>
    </div>

    <div class="container-fluid d-flex justify-content-center align-items-center min-vh-100">
        <div class="card modern-card shadow-lg p-5 rounded-4">
            <div class="text-center mb-5">
                <h3 class="login-title mb-2">Welcome Back</h3>
                <p class="login-subtitle">Sign in to your account</p>
            </div>

            <form asp-action="Login" method="post" class="mt-4">
                @Html.ValidationSummary(true, "", new { @class = "modern-text-danger mb-4" })

                <div class="mb-4">
                    @Html.LabelFor(model => model.Email, new { @class = "form-label modern-label fw-semibold" })
                    @Html.TextBoxFor(model => model.Email, new { @class = "form-control modern-form-control rounded-4", placeholder = "Enter your email address" })
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "modern-text-danger mt-2" })
                </div>

                <div class="mb-4">
                    @Html.LabelFor(model => model.Password, new { @class = "form-label modern-label fw-semibold" })
                    @Html.PasswordFor(model => model.Password, new { @class = "form-control modern-form-control rounded-4", placeholder = "Enter your password" })
                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "modern-text-danger mt-2" })
                </div>

                @* <div class="form-group mb-4 form-check">
                    @Html.CheckBoxFor(model => model.RememberMe, new { @class = "form-check-input" })
                    @Html.LabelFor(model => model.RememberMe, new { @class = "form-check-label modern-text-white" })
                </div> *@

                <button type="submit" class="btn modern-btn-primary w-100 rounded-4 mb-4">
                    Sign In
                </button>

                <div class="text-center">
                    <hr class="my-4" style="border-color: rgba(59, 130, 246, 0.2);">
                    <p class="modern-text-white mb-0">
                        Don't have an account yet?
                        <a asp-action="Signup" asp-controller="Account" class="modern-link ms-2">Create Account</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

