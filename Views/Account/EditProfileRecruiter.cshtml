@model User
@{
    ViewBag.Title = "Update the Job";
}

<style>
    .gradient-bg {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    .form-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
        }

    .form-title {
        background: linear-gradient(45deg, #667eea, #764ba2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 700;
        text-align: center;
        margin-bottom: 2rem;
        font-size: 2rem;
    }

    .form-control {
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
    }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 20px rgba(102, 126, 234, 0.2);
            background: rgba(255, 255, 255, 1);
            transform: translateY(-2px);
        }

    .form-label {
        color: #495057;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .btn-update {
        background: linear-gradient(45deg, #28a745, #20c997);
        border: none;
        font-weight: 600;
        padding: 12px 30px;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .btn-update::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-update:hover::before {
            left: 100%;
        }

        .btn-update:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(40, 167, 69, 0.3);
            background: linear-gradient(45deg, #34ce57, #17a2b8);
        }

    .form-floating {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .floating-label {
        position: absolute;
        top: 50%;
        left: 15px;
        transform: translateY(-50%);
        background: white;
        padding: 0 8px;
        color: #6c757d;
        transition: all 0.3s ease;
        pointer-events: none;
        font-size: 0.9rem;
    }

    .form-control:focus + .floating-label,
    .form-control:not(:placeholder-shown) + .floating-label {
        top: 0;
        font-size: 0.8rem;
        color: #667eea;
        font-weight: 600;
    }

    .validation-message {
        color: #e74c3c;
        font-size: 0.85rem;
        margin-top: 0.25rem;
        animation: shake 0.5s ease-in-out;
    }

    @@keyframes shake {
        0%, 20%, 40%, 60%, 80% {
            transform: translateX(0);
        }

        10%, 30%, 50%, 70%, 90% {
            transform: translateX(-3px);
        }
    }

    .input-group {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .input-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        z-index: 5;
        font-size: 1.1rem;
    }

    textarea.form-control {
        min-height: 100px;
        resize: vertical;
    }

    .card-header {
        background: linear-gradient(45deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
        padding: 1.5rem;
        border-radius: 1rem 1rem 0 0 !important;
    }
</style>

<div class="gradient-bg d-flex justify-content-center align-items-center">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8 col-sm-10">
                <div class="card form-card border-0 rounded-4">
                    <div class="card-header">
                        <h2 class="form-title mb-0">Update Job Profile</h2>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="EditProfileRecruiter" method="post">
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger rounded-3" })


                            <div class="input-group">
                                @Html.LabelFor(model => model.Name, new { @class = "form-label", style = "padding-top:10px" }) &nbsp;&nbsp;
                                @Html.TextBoxFor(model => model.Name, new { @class = "form-control rounded-pill", placeholder = " " })
                                <i class="fas fa-user input-icon"></i>
                                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "validation-message" })
                            </div>
                            <div class="input-group">
                                @Html.LabelFor(model => model.CName, new { @class = "form-label", style = "padding-top:10px" }) &nbsp;&nbsp;
                                @Html.TextBoxFor(model => model.CName, new { @class = "form-control rounded-pill", placeholder = " " })
                                <i class="fas fa-user input-icon"></i>
                                @Html.ValidationMessageFor(model => model.CName, "", new { @class = "validation-message" })
                            </div>

                            <div class="input-group">
                                @Html.LabelFor(model => model.Description, new { @class = "form-label" })&nbsp;&nbsp;
                                @Html.TextAreaFor(model => model.Description, new { @class = "form-control rounded-3", placeholder = " ", rows = "4" })
                                <i class="fas fa-align-left input-icon"></i>
                                @Html.ValidationMessageFor(model => model.Description, "", new { @class = "validation-message" })
                            </div>


                            <div class="input-group">
                                @Html.LabelFor(model => model.IType, new { @class = "form-label", style = "padding-top:10px" }) &nbsp;&nbsp;
                                @Html.TextBoxFor(model => model.IType, new { @class = "form-control rounded-pill", placeholder = " " })
                                <i class="fas fa-tools input-icon"></i>
                                @Html.ValidationMessageFor(model => model.IType, "", new { @class = "validation-message" })
                            </div>


                            <div class="input-group">
                                @Html.LabelFor(model => model.Address, new { @class = "form-label", style = "padding-top:10px" }) &nbsp;&nbsp;
                                @Html.TextBoxFor(model => model.Address, new { @class = "form-control rounded-pill", placeholder = " " })
                                <i class="fas fa-briefcase input-icon"></i>
                                @Html.ValidationMessageFor(model => model.Address, "", new { @class = "validation-message" })
                            </div>


                            <div class="input-group">
                                @Html.LabelFor(model => model.CSize, new { @class = "form-label", style = "padding-top:10px" }) &nbsp;&nbsp;
                                @Html.TextBoxFor(model => model.CSize,  new { @class = "form-control rounded-pill" })
                                <i class="fas fa-calendar-alt input-icon"></i>
                                @Html.ValidationMessageFor(model => model.CSize, "", new { @class = "validation-message" })
                            </div>


                            <div class="input-group">
                                @Html.LabelFor(model => model.ContactNo, new { @class = "form-label", style = "padding-top:10px" }) &nbsp;&nbsp;
                                @Html.TextBoxFor(model => model.ContactNo, new { @class = "form-control rounded-pill", placeholder = " " })
                                <i class="fas fa-id-badge input-icon"></i>
                                @Html.ValidationMessageFor(model => model.ContactNo, "", new { @class = "validation-message" })
                            </div>

                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-update text-white w-100 rounded-pill">
                                    <i class="fas fa-sync-alt me-2"></i>Update Profile
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">