@model User

@{
    ViewData["Title"] = "User Information Form";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">User Information Form</h3>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("GetApplicantDetails", "Account", FormMethod.Post))
                    {
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        
                        <div class="form-group mb-3">
                            @Html.LabelFor(model => model.Description, htmlAttributes: new { @class = "form-label fw-bold" })
                            @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = 4, placeholder = "Enter a brief description about yourself...", maxlength = "500" })
                            @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                            <div class="form-text">Maximum 500 characters</div>
                        </div>

                        
                        <div class="form-group mb-3">
                            @Html.LabelFor(model => model.Skills, htmlAttributes: new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(model => model.Skills, new { @class = "form-control", placeholder = "e.g., C#, JavaScript, SQL Server, Azure...", maxlength = "200" })
                            @Html.ValidationMessageFor(model => model.Skills, "", new { @class = "text-danger" })
                            <div class="form-text">List your technical skills separated by commas</div>
                        </div>

                        
                        <div class="form-group mb-3">
                            @Html.LabelFor(model => model.Experience, htmlAttributes: new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(model => model.Experience, new { @class = "form-control", placeholder = "e.g., 5 years in software development...", maxlength = "100" })
                            @Html.ValidationMessageFor(model => model.Experience, "", new { @class = "text-danger" })
                            <div class="form-text">Brief summary of your work experience</div>
                        </div>

                        
                        <div class="form-group mb-3">
                            @Html.LabelFor(model => model.DOB, htmlAttributes: new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(model => model.DOB, new { @class = "form-control", placeholder = "Enter your date of birth (e.g., 01-Jan-1990)" })
                            @Html.ValidationMessageFor(model => model.DOB, "", new { @class = "text-danger" })
                            <div class="form-text">Enter your date of birth in a readable format</div>
                        </div>


                        <div class="form-group mb-4">
                            @Html.LabelFor(model => model.JobRole, htmlAttributes: new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(model => model.JobRole, new { @class = "form-control", placeholder = "Enter your job role..." })
                            @Html.ValidationMessageFor(model => model.JobRole, "", new { @class = "text-danger" })
                        </div>

                        
                        <div class="form-group text-center">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-paper-plane me-2"></i>Submit Information
                            </button>
                            <button type="reset" class="btn btn-secondary btn-lg px-5 ms-3">
                                <i class="fas fa-undo me-2"></i>Reset Form
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="{
      @{
          await Html.RenderPartialAsync("_ValidationScriptsPartial");
      }
