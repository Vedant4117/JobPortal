@model IEnumerable<Jobs>
@{
    ViewBag.Title = "Job Listings";
    string role = ViewBag.role as string;
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --success-gradient: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        --warning-gradient: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
        --glass-bg: rgba(255, 255, 255, 0.9);
        --glass-border: rgba(255, 255, 255, 0.3);
        --shadow-color: rgba(102, 126, 234, 0.15);
    }

    .modern-page-header {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        border: 1px solid var(--glass-border);
        box-shadow: 0 20px 40px var(--shadow-color);
        position: relative;
        overflow: hidden;
    }

        .modern-page-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
            border-radius: 20px 20px 0 0;
        }

    .modern-create-container {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0;
    }

    .modern-create-btn {
        background: var(--primary-gradient) !important;
        border: none !important;
        border-radius: 50% !important;
        width: 60px !important;
        height: 60px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4) !important;
        transition: all 0.3s ease !important;
        position: relative;
        overflow: hidden;
    }

        .modern-create-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s;
        }

        .modern-create-btn:hover::before {
            left: 100%;
        }

        .modern-create-btn:hover {
            transform: translateY(-3px) scale(1.05) !important;
            box-shadow: 0 15px 35px rgba(102, 126, 234, 0.5) !important;
        }

        .modern-create-btn i {
            color: white;
            font-size: 1.4rem;
            transition: transform 0.3s ease;
        }

        .modern-create-btn:hover i {
            transform: rotate(90deg);
        }

    .modern-create-text {
        font-size: 1.2rem;
        font-weight: 600;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .modern-job-card {
        background: var(--glass-bg) !important;
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border) !important;
        border-radius: 24px !important;
        padding: 1.75rem !important;
        margin-bottom: 1.5rem !important;
        box-shadow: 0 15px 35px rgba(102, 126, 234, 0.08) !important;
        transition: all 0.3s ease !important;
        position: relative;
        overflow: hidden;
    }

        .modern-job-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--primary-gradient);
            transform: translateY(-3px);
            transition: transform 0.3s ease;
        }

        .modern-job-card:hover {
            transform: translateY(-8px) !important;
            box-shadow: 0 25px 50px rgba(102, 126, 234, 0.15) !important;
        }

            .modern-job-card:hover::before {
                transform: translateY(0);
            }

    .modern-job-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .modern-job-title {
        font-size: 1.4rem !important;
        font-weight: 700 !important;
        color: #2d3748 !important;
        margin-bottom: 0.5rem !important;
        line-height: 1.3;
    }

    .modern-job-location {
        color: #718096 !important;
        font-size: 0.95rem !important;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .modern-job-location::before {
            content: '\f3c5';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            color: #667eea;
        }

    .modern-dropdown-btn {
        background: transparent !important;
        border: 2px solid rgba(102, 126, 234, 0.2) !important;
        border-radius: 12px !important;
        width: 40px !important;
        height: 40px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: 1.2rem !important;
        color: #667eea !important;
        transition: all 0.3s ease !important;
    }

        .modern-dropdown-btn:hover {
            background: rgba(102, 126, 234, 0.1) !important;
            border-color: rgba(102, 126, 234, 0.4) !important;
            transform: rotate(90deg);
        }

    .modern-dropdown-menu {
        background: var(--glass-bg) !important;
        backdrop-filter: blur(20px) !important;
        border: 1px solid var(--glass-border) !important;
        border-radius: 16px !important;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15) !important;
        padding: 0.75rem 0 !important;
        margin-top: 0.5rem !important;
        min-width: 180px !important;
    }

    .modern-dropdown-item {
        padding: 0.75rem 1.25rem !important;
        font-weight: 500 !important;
        color: #4a5568 !important;
        transition: all 0.2s ease !important;
        border-radius: 0 !important;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .modern-dropdown-item:hover {
            background: rgba(102, 126, 234, 0.1) !important;
            color: #667eea !important;
            padding-left: 1.75rem !important;
        }

        .modern-dropdown-item.text-danger {
            color: #e53e3e !important;
        }

            .modern-dropdown-item.text-danger:hover {
                background: rgba(229, 62, 62, 0.1) !important;
                color: #e53e3e !important;
            }

    .modern-job-description {
        color: #4a5568 !important;
        font-size: 1rem !important;
        line-height: 1.6;
        margin-bottom: 1.5rem !important;
        padding: 1rem;
        background: rgba(102, 126, 234, 0.05);
        border-radius: 12px;
        border-left: 4px solid #667eea;
    }

    .modern-job-meta {
        display: flex !important;
        flex-wrap: wrap !important;
        gap: 1.5rem !important;
        font-size: 0.9rem !important;
        color: #2d3748 !important;
    }

    .modern-meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.8);
        border-radius: 20px;
        border: 1px solid rgba(102, 126, 234, 0.1);
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .modern-meta-item:hover {
            background: rgba(102, 126, 234, 0.1);
            border-color: rgba(102, 126, 234, 0.2);
            transform: translateY(-2px);
        }

        .modern-meta-item strong {
            color: #667eea;
        }

    .modern-salary::before {
        content: '\f155';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        color: #38a169;
    }

    .modern-date::before {
        content: '\f017';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        color: #ed8936;
    }

    .modern-status::before {
        content: '\f058';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        color: #667eea;
    }

    .modern-alert {
        background: rgba(30, 64, 175, 0.1) !important;
        border: 1px solid rgba(30, 64, 175, 0.2) !important;
        border-radius: 16px !important;
        padding: 1rem 1.5rem !important;
        margin-bottom: 2rem !important;
        color: #1e40af !important;
    }

    @@media (max-width: 768px) {
        .modern-page-header {
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .modern-job-card {
            padding: 1.25rem !important;
            margin-bottom: 1rem !important;
        }

        .modern-job-header {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }

        .modern-job-meta {
            gap: 1rem !important;
        }

        .modern-meta-item {
            font-size: 0.85rem;
            padding: 0.4rem 0.8rem;
        }

        .modern-create-container {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }
    }

    /* Animation */
    .modern-job-card {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modern-job-card:nth-child(1) {
        animation-delay: 0.1s;
    }

    .modern-job-card:nth-child(2) {
        animation-delay: 0.2s;
    }

    .modern-job-card:nth-child(3) {
        animation-delay: 0.3s;
    }

    .modern-job-card:nth-child(4) {
        animation-delay: 0.4s;
    }

    .modern-job-card:nth-child(5) {
        animation-delay: 0.5s;
    }
</style>

@if (ViewBag.alert != null)
{
    <div class="modern-alert">
        @Html.ValidationSummary(true, "", new { @class = "mb-0" })
    </div>
}

<div class="modern-page-header">
    <div class="modern-create-container">
        <form asp-action="Create" asp-controller="Employer" method="get" class="d-inline-block">
            @* @Html.AntiForgeryToken() *@
            <button type="submit" class="btn modern-create-btn">
                <i class="fas fa-plus"></i>
            </button>
        </form>
        <h2 class="modern-create-text">Create a Job Posting</h2>
    </div>
</div>

<div class="row g-4">
    @foreach (var job in Model)
    {
        <div class="col-12">
            <div class="modern-job-card">
                <div class="modern-job-header">
                    <div class="flex-grow-1">
                        <h5 class="modern-job-title">@Html.DisplayFor(m => job.Title)</h5>
                        <div class="modern-job-location">@Html.DisplayFor(m => job.Location)</div>
                    </div>
                    <div class="dropdown">
                        <button class="btn modern-dropdown-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            &#x22EE;
                        </button>
                        <ul class="dropdown-menu modern-dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item modern-dropdown-item" asp-action="Update" asp-controller="Employer" asp-route-id="@job.JobId">
                                    <i class="fas fa-edit"></i>Edit Job
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item modern-dropdown-item" asp-action="Applicants" asp-controller="Employer" asp-route-id="@job.JobId">
                                    <i class="fas fa-users"></i>View Applicants
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" style="opacity: 0.2; margin: 0.5rem 0;"></li>
                            <li>
                                <form asp-action="Delete" asp-controller="Employer" method="post" class="d-inline-block w-100">
                                    <input type="hidden" name="id" value="@job.JobId" />
                                    <button type="submit" class="dropdown-item modern-dropdown-item text-danger w-100 text-start border-0 bg-transparent">
                                        <i class="fas fa-trash-alt"></i>Delete Job
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="modern-job-description">
                    @Html.DisplayFor(m => job.Description)
                </div>

                <div class="modern-job-meta">
                    <div class="modern-meta-item modern-salary">
                        <strong>Salary:</strong> ₹@Html.DisplayFor(m => job.Salary)
                    </div>
                    <div class="modern-meta-item modern-date">
                        <strong>Posted:</strong> @Html.DisplayFor(m => job.PostedDate)
                    </div>
                    <div class="modern-meta-item modern-status">
                        <strong>Status:</strong> @Html.DisplayFor(m => job.Status)
                    </div>
                </div>
            </div>
        </div>
    }
</div>